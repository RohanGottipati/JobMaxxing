# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Development-only preview mode for the UI while Supabase is still pending.
# Set to false once real Supabase auth is ready locally.
NEXT_PUBLIC_ENABLE_AUTH_PREVIEW=true
